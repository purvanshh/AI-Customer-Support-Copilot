# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
DATA_DIR=data
LOG_DIR=logs

# ---------------------------------------------------------------------------
# Embeddings — mock | sentence_transformers | openai
# ---------------------------------------------------------------------------
EMBEDDING_BACKEND=mock
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# LLM — mock | openai | gemini
# ---------------------------------------------------------------------------
LLM_BACKEND=mock
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-pro

# API keys (required only for non-mock backends)
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*
